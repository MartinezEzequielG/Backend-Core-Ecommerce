generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(CUSTOMER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]
  carts  Cart[]
}

enum Role {
  SUPERADMIN
  ADMIN
  EDITOR
  CUSTOMER
}

model Category {
  id          Int        @id @default(autoincrement())
  name        String
  slug        String     @unique
  description String?
  imageUrl    String?
  parentId    Int?
  parent      Category?  @relation("CategoryToCategory", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryToCategory")

  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id               Int       @id @default(autoincrement())
  name             String
  slug             String    @unique
  description      String?   @db.LongText
  basePrice        Decimal   @db.Decimal(10, 2)
  salePrice        Decimal?  @db.Decimal(10, 2)
  discountTransfer Float? // % OFF por transferencia
  discountMp       Float? // % OFF por MercadoPago
  isNew            Boolean?  @default(false)
  isHot            Boolean?  @default(false)
  freeShipping     Boolean?  @default(false)
  sku              String?   @unique
  active           Boolean   @default(true)
  featured         Boolean   @default(false)
  categoryId       Int?
  category         Category? @relation(fields: [categoryId], references: [id])
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  images     ProductImage[]
  options    ProductOption[]
  variants   ProductVariant[]
  orderItems OrderItem[]
  cartItems  CartItem[]

  productAudits ProductAudit[]

  @@index([active, createdAt])
  @@index([categoryId, active, createdAt])
}

model ProductImage {
  id        Int    @id @default(autoincrement())
  productId Int
  url       String
  position  Int    @default(0)

  product Product @relation(fields: [productId], references: [id])

  variants ProductVariant[] @relation("VariantImage")
}

model ProductOption {
  id        Int    @id @default(autoincrement())
  productId Int
  name      String

  product Product              @relation(fields: [productId], references: [id])
  values  ProductOptionValue[]
}

model ProductOptionValue {
  id       Int           @id @default(autoincrement())
  optionId Int
  value    String
  product  ProductOption @relation(fields: [optionId], references: [id])

  variantOptions ProductVariantOption[]
}

model ProductVariant {
  id        Int      @id @default(autoincrement())
  productId Int
  sku       String?  @unique
  price     Decimal? @db.Decimal(10, 2)

  onHand   Int @default(0) // stock físico
  reserved Int @default(0) // reservado por checkouts pendientes

  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product    Product                @relation(fields: [productId], references: [id])
  options    ProductVariantOption[]
  orderItems OrderItem[]
  cartItems  CartItem[]

  reservationItems StockReservationItem[]

  imageId Int?
  image   ProductImage? @relation("VariantImage", fields: [imageId], references: [id], onDelete: SetNull)

  @@index([productId, active])
  @@index([productId, onHand])
  @@index([imageId])
}

model ProductVariantOption {
  id            Int @id @default(autoincrement())
  variantId     Int
  optionValueId Int

  variant     ProductVariant     @relation(fields: [variantId], references: [id])
  optionValue ProductOptionValue @relation(fields: [optionValueId], references: [id])

  @@unique([variantId, optionValueId])
}

model Cart {
  id           Int      @id @default(autoincrement())
  userId       Int?     @unique
  sessionToken String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user  User?      @relation(fields: [userId], references: [id])
  items CartItem[]

  @@index([userId])
  @@index([sessionToken])
}

model CartItem {
  id               Int     @id @default(autoincrement())
  cartId           Int
  productId        Int
  productVariantId Int?
  quantity         Int     @default(1)
  unitPrice        Decimal @db.Decimal(10, 2)

  cart           Cart            @relation(fields: [cartId], references: [id])
  product        Product         @relation(fields: [productId], references: [id])
  productVariant ProductVariant? @relation(fields: [productVariantId], references: [id])

  @@index([cartId])
  @@index([cartId, productId, productVariantId])
}

model Order {
  id     Int         @id @default(autoincrement())
  userId Int?
  status OrderStatus @default(PENDING_PAYMENT)

  total        Decimal @db.Decimal(10, 2)
  shippingCost Decimal @db.Decimal(10, 2)

  paymentMethod String?
  paymentStatus String?
  externalRef   String? @unique

  checkoutToken String? @unique @db.VarChar(64)

  guestSessionToken String? @db.VarChar(128)

  reservedUntil DateTime?
  cancelReason  String?   @db.VarChar(191)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trackingCode String?
  shippedAt    DateTime?
  deliveredAt  DateTime?
  paidAt       DateTime?

  user            User?             @relation(fields: [userId], references: [id])
  items           OrderItem[]
  shippingAddress ShippingAddress?
  reservation     StockReservation? @relation("OrderReservation")

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([guestSessionToken, createdAt])
  @@index([id, guestSessionToken])
}

enum OrderStatus {
  CREATED // orden creada pero aún no se inició pago (opcional)
  PENDING_PAYMENT // esperando pago (checkout ya validado + stock reservado)
  PAID // pago confirmado
  PROCESSING // preparando pedido
  SHIPPED
  DELIVERED
  CANCELLED // cancelada/expirada
  FAILED // pago fallido
}

model OrderItem {
  id               Int     @id @default(autoincrement())
  orderId          Int
  productId        Int
  productVariantId Int?
  quantity         Int
  unitPrice        Decimal @db.Decimal(10, 2)

  order          Order           @relation(fields: [orderId], references: [id])
  product        Product         @relation(fields: [productId], references: [id])
  productVariant ProductVariant? @relation(fields: [productVariantId], references: [id])
}

model ShippingAddress {
  id      Int @id @default(autoincrement())
  orderId Int @unique

  fullName String
  email    String? @db.VarChar(191) // nota: nuevo
  phone    String
  street   String
  city     String
  state    String
  zip      String?
  country  String

  order Order @relation(fields: [orderId], references: [id])
}

model StockReservation {
  id                Int     @id @default(autoincrement())
  orderId           Int     @unique
  userId            Int?
  guestSessionToken String? @db.VarChar(128)

  status    ReservationStatus @default(ACTIVE)
  expiresAt DateTime

  items StockReservationItem[]
  order Order                  @relation("OrderReservation", fields: [orderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, expiresAt])
  @@index([guestSessionToken])
}

model StockReservationItem {
  id            Int @id @default(autoincrement())
  reservationId Int
  variantId     Int
  quantity      Int

  reservation StockReservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  variant     ProductVariant   @relation(fields: [variantId], references: [id])

  @@unique([reservationId, variantId])
  @@index([variantId])
}

enum ReservationStatus {
  ACTIVE
  RELEASED
  CONSUMED
  EXPIRED
}

model StoreSettings {
  id             Int     @id @default(autoincrement())
  name           String
  logoUrl        String?
  primaryColor   String?
  secondaryColor String?
  contactEmail   String?
  currency       String  @default("ARS")
  whatsappNumber String?
  address        String?
  ownerFullName  String?
  ownerPhone     String?
  ownerEmail     String?
  documentType   String?
  documentNumber String?
  heroVideoUrl   String?
  heroImageUrl   String?
  heroMode       String?

  checkoutMode String @default("CATALOG") // "CATALOG" | "CART"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Coupon {
  id        Int        @id @default(autoincrement())
  code      String     @unique
  type      CouponType
  value     Decimal
  active    Boolean    @default(true)
  expiresAt DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

enum CouponType {
  PERCENT
  FIXED
}

model ProductAudit {
  id        Int      @id @default(autoincrement())
  productId Int
  action    String
  details   Json?
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])
}

model SiteConfig {
  id          Int      @id @default(1)
  banners     Json     @default("[]")
  socialLinks Json     @default("[]")
  updatedAt   DateTime @updatedAt
}

model PaymentEvent {
  id          Int      @id @default(autoincrement())
  provider    String
  externalRef String
  orderId     Int?
  payload     Json
  status      String // "applied" | "ignored" | "duplicate" | "invalid_signature"
  createdAt   DateTime @default(now())
}
